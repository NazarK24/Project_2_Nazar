[
    {
      "name": "backend-rds",
      "image": "${BACKEND_RDS_IMAGE_URL}",
      "cpu": 256,
      "memory": 512,
      "portMappings": [
        {
          "containerPort": ${CONTAINER_PORT},
          "hostPort": ${CONTAINER_PORT}
        }
      ],
      "environment": [
        { "name": "DB_NAME", "value": "${DB_NAME}" },
        { "name": "DB_USER", "value": "${DB_USER}" },
        { "name": "DB_PASSWORD", "value": "${DB_PASSWORD}" }
      ],
      "essential": true
    }
  ]  